# Copy this file to .streamlit/secrets.toml for LOCAL testing (that file is
# git-ignored — never commit real secrets). For Streamlit Community Cloud,
# paste the same content into your app's Settings -> Secrets instead.

SUPABASE_URL = "https://cldeynpwcejvbmmkckgt.supabase.co"

# IMPORTANT: use the service_role key, NOT the anon/publishable key.
# RLS is enabled with no policies on every table in this project, so the
# anon key has zero access by design — only service_role can read/write.
# Get it from: Supabase dashboard -> your project -> Settings -> API
# -> "service_role" secret key (starts with "eyJ..." or "sb_secret_...").
# Never paste this key into client-side code, a public repo, or share it
# outside this app's secrets manager.
SUPABASE_SERVICE_ROLE_KEY = "paste-your-service-role-key-here"

# Single shared password gating the admin pages (Target Management,
# Data Management). Change this to something only you know.
ADMIN_PASSWORD = "change-me"
